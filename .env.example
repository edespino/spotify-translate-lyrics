# Spotify app client ID (create an app at https://developer.spotify.com/dashboard)
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id

# Gemini API key (get one at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# Gemini model (optional). The default, gemini-2.5-flash-lite, has a
# higher free-tier request rate than gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash-lite

# Ports (optional, these are the defaults)
VITE_PORT=5173
SERVER_PORT=8087
